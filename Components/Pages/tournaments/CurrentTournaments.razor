@page "/tournaments/current"
@using ArcheryScorecard.Interfaces
@using ArcheryScorecard.Models
@inject ITournamentService TournamentService
@inject NavigationManager Navigation

<h3>Current Tournaments</h3>

@if (tournaments is null)
{
    <p>Loading...</p>
}
else if (!tournaments.Any())
{
    <p>No current tournaments found.</p>
}
else
{
    <ul class="list-group">
        @foreach (var tournament in tournaments)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <span>
                    <strong>@tournament.Name</strong> – @tournament.Date.ToShortDateString()
                </span>
                <button class="btn btn-sm btn-primary"
                        @onclick="@(() => NavigateToDetails(tournament.Id))">
                    View
                </button>
            </li>
        }
    </ul>
}

@code {
    private IEnumerable<Tournament>? tournaments;

    protected override async Task OnInitializedAsync()
    {
        tournaments = await TournamentService.GetCurrentTournamentsAsync();
    }

    private void NavigateToDetails(Guid id)
    {
        Navigation.NavigateTo($"/tournaments/details/{id}");
    }
}