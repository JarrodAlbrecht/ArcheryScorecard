@page "/tournaments/create"
@using ArcheryScorecard.Interfaces
@using ArcheryScorecard.Models
@using ArcheryScorecard.Models.Enums

@inject ITournamentService TournamentService
@inject NavigationManager Navigation

<h3>Create New Tournament</h3>

<EditForm Model="tournament" OnValidSubmit="HandleValidSubmit" FormName="CreateTournamentForm">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label for="name">Tournament Name</label>
        <InputText id="name" class="form-control" @bind-Value="tournament.Name" />
    </div>

    <div class="mb-3">
        <label for="type">Tournament Type</label>
        <InputSelect id="type" class="form-control" @bind-Value="tournament.Type" TValue="TournamentType">
            @foreach (var type in Enum.GetValues(typeof(TournamentType)).Cast<TournamentType>())
            {
                <option value="@type">@type</option>
            }
        </InputSelect>
    </div>

    <div class="mb-3">
        <label for="bow">Bow Style</label>
        <InputSelect id="bow" class="form-control" @bind-Value="tournament.BowStyle" TValue="BowStyle">
            @foreach (var style in Enum.GetValues(typeof(BowStyle)).Cast<BowStyle>())
            {
                <option value="@style">@style</option>
            }
        </InputSelect>
    </div>

    <div class="mb-3">
        <label for="date">Date</label>
        <InputDate id="date" class="form-control" @bind-Value="tournament.Date" />
    </div>

    <div class="mb-3">
        <label>Shooting Distance (meters)</label>
        <InputNumber class="form-control" @bind-Value="newDistance" />
        <button type="button" class="btn btn-secondary mt-1" @onclick="AddDistance">Add Distance</button>
    </div>

    @if (tournament.TournamentShootingDistances.Any())
    {
        <div class="mb-3">
            <label>Distances Added:</label>
            <ul>
                @foreach (var d in tournament.TournamentShootingDistances)
                {
                    <li>
                        @d m
                        <button type="button" class="btn btn-sm btn-danger" @onclick="() => RemoveDistance(d)">Remove</button>
                    </li>
                }
            </ul>
        </div>
    }

    <button type="submit" class="btn btn-primary">Save Tournament</button>
</EditForm>

@if (!string.IsNullOrEmpty(feedbackMessage))
{
    <div class="alert alert-info mt-3">@feedbackMessage</div>
}

@code {
    private Tournament tournament = new()
    {
        Id = Guid.NewGuid(),
        Name = string.Empty,
        Type = TournamentType.Indoor,
        BowStyle = BowStyle.Recurve,
        Date = DateTime.Today,
        Archers = new(),
        ArcheryEnds = new(),
        TournamentShootingDistances = new(),
        Rounds = new()
    };

    private int newDistance;
    private string? feedbackMessage;

    private void AddDistance()
    {
        if (newDistance > 0 && !tournament.TournamentShootingDistances.Contains(newDistance))
        {
            tournament.TournamentShootingDistances.Add(newDistance);
            newDistance = 0;
        }
    }

    private void RemoveDistance(int dist)
    {
        tournament.TournamentShootingDistances.Remove(dist);
    }

    private async Task HandleValidSubmit()
    {
        bool success = await TournamentService.CreateTournamentAsync(tournament);
        feedbackMessage = success
            ? "Tournament saved successfully!"
            : "Failed to save tournament.";

        if (success)
        {
            Console.WriteLine($"Tournament '{tournament.Name}' saved.");
            Navigation.NavigateTo("/tournaments/current");
        }
    }
}
